{
  "version": 2,
  "framework": null,
  "installCommand": "echo 'Flutter build — handled in buildCommand'",
  "buildCommand": "curl -fsSL https://storage.googleapis.com/flutter_infra_release/releases/stable/linux/flutter_linux_3.29.2-stable.tar.xz -o /tmp/flutter.tar.xz && tar -xf /tmp/flutter.tar.xz -C /opt/ && export PATH=\"/opt/flutter/bin:$PATH\" && flutter --disable-analytics && flutter pub get && flutter build web --release --web-renderer canvaskit --dart-define=API_BASE_URL=${API_BASE_URL:-https://api.promptgenie.app} --dart-define=ENVIRONMENT=production",
  "outputDirectory": "build/web",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/flutter_service_worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css|wasm|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    }
  ],
  "env": {
    "API_BASE_URL": "https://api.promptgenie.app"
  }
}
