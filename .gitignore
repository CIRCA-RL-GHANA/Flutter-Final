# ============================================
# Flutter / Dart .gitignore
# ============================================

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# VS Code
.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/
**/ios/Pods/
**/ios/.symlinks/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
pubspec.lock

# Web related
lib/generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio related
/android/app/debug
/android/app/profile
/android/app/release

# Environment files
.env
.env.*
!.env.example

# Secrets & signing
*.jks
*.keystore
android/keystore.properties
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
ios/Runner/firebase_app_id_file.json

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Coverage
coverage/
test/.test_coverage.dart

# Temp
.tmp/
temp/
