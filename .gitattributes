# Normalize line endings to LF in the repo, checkout as LF on all platforms
* text=auto eol=lf

# Shell scripts — always LF
*.sh text eol=lf
*.bash text eol=lf

# YAML — always LF
*.yml text eol=lf
*.yaml text eol=lf

# Dart / Flutter
*.dart text eol=lf
*.json text eol=lf

# Config / env
*.env text eol=lf
*.conf text eol=lf

# Binaries — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.tar binary
*.gz binary
*.aab binary
*.apk binary
*.ipa binary
