# ───────────────────────────────────────────────────────
# Flutter Application Configuration (.env)
# ───────────────────────────────────────────────────────
# This file provides environment-specific settings for the Flutter app.
# Read CONFIGURATION_GUIDE.md for complete setup instructions.

# ─── ENVIRONMENT & VERSION ─────────────
# Environment mode: development, staging, production
APP_ENV=development

# API versioning
API_VERSION=v1

# ─── BACKEND API CONFIGURATION ─────────────
# API base URL - varies by platform and environment
# Android Emulator: http://10.0.2.2:3000 (special Android emulator IP)
# Android Device: http://192.168.x.x:3000 (actual device on local network)
# iOS Simulator: http://localhost:3000 (localhost works for iOS)
# iOS Device: http://api.genieinprompt.app:3000 (production URL)
API_BASE_URL=http://10.0.2.2:3000

# API timeout in seconds (for production: 30s recommended)
API_TIMEOUT=15

# ─── AUTHENTICATION & SECURITY ─────────────
# JWT token storage location (SECURE_STORAGE is recommended)
TOKEN_STORAGE=SECURE_STORAGE

# Enable/disable biometric authentication
FEATURE_BIOMETRIC_AUTH=true

# ─── FEATURE FLAGS ─────────────
# Toggle features on/off without redeployment
FEATURE_OFFLINE_SUPPORT=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_REAL_TIME_CHAT=true
FEATURE_RIDE_HAILING=true
FEATURE_FINANCIAL_OPERATIONS=true
FEATURE_AI_ASSISTANT=true
FEATURE_MARKETPLACE=true
FEATURE_ADVANCED_ANALYTICS=false

# ─── THIRD-PARTY SERVICES ─────────────
# Google Maps API Key (required for location and maps)
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Firebase Project ID (for notifications, analytics, auth)
# Configured via google-services.json (Android) and GoogleService-Info.plist (iOS)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Sentry DSN (optional, for error tracking in production)
# Get from: https://sentry.io/
SENTRY_DSN=

# ─── STORAGE & CACHING ─────────────
# Hive database encryption key (optional, for local data encryption)
# Generate: base64 of 32 random bytes
HIVE_ENCRYPTION_KEY=

# Cache expiry duration in hours
CACHE_EXPIRY_HOURS=24

# ─── LOCALIZATION & THEME ─────────────
# Default language code (ISO 639-1)
DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=en,es,fr

# Theme mode: light, dark, system
THEME_MODE=system

# ─── LOGGING & DEBUGGING ─────────────
# Log level: none, verbose, debug, info, warning, error
LOG_LEVEL=debug

# Enable network request logging (disable in production)
LOG_HTTP_REQUESTS=true

# Enable error stack traces in console (disable in production)
LOG_STACK_TRACES=true

# ─── PLATFORM-SPECIFIC ─────────────
# Minimum iOS version (should match pubspec.yaml)
IOS_MIN_VERSION=12.0

# Minimum Android SDK version (should match build.gradle)
ANDROID_MIN_SDK=21

# ─── ANALYTICS & TELEMETRY ─────────────
# Enable anonymous usage analytics (GA4 or similar)
ANALYTICS_ENABLED=true

# Collect crash data for analysis
CRASH_COLLECTION_ENABLED=true

# ─── BUILD & PERFORMANCE ─────────────
# Enable performance monitoring (do NOT use in release builds)
PERFORMANCE_MONITORING=false

# Profile mode settings (only for profiling, not production)
PROFILING_ENABLED=false

# ─── DEVELOPMENT & TESTING ─────────────
# Force API errors for testing error handling
FORCE_API_ERRORS=false

# Mock location data (disable in production)
MOCK_LOCATION_DATA=false

# Use test payment gateway (disable in production)
USE_TEST_PAYMENT_GATEWAY=true

# ─── PRODUCTION/STAGING OVERRIDES ─────────────
# NOTE: These should ONLY be set when APP_ENV=production or APP_ENV=staging
# PRODUCTION API base URL (actual server, not localhost)
# API_BASE_URL=https://api.genieinprompt.app

# PRODUCTION Google Maps API key (different key for production)
# GOOGLE_MAPS_API_KEY=prod-google-maps-api-key

# ───────────────────────────────────────────────────────
# For complete configuration options, see:
# - CONFIGURATION_GUIDE.md (main Flutter configuration)
# - README.md (project overview)
# - MASTER_DEVELOPER_DOCUMENTATION.md (developer guide)
# ───────────────────────────────────────────────────────

