<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>genie help</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>genie help</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- App Transport Security - HTTPS Only -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<!-- Permission Descriptions (required for App Store) -->
	<key>NSCameraUsageDescription</key>
	<string>genie help needs camera access to take profile photos, scan QR codes, and capture documents for verification.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>genie help needs photo library access to select profile pictures and upload images to your business listings.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>genie help needs to save receipts, QR codes, and shared images to your photo library.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>genie help uses your location to show nearby shops, drivers, and provide accurate ride and delivery estimates.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>genie help uses your location in the background to track active rides and deliveries so you and your customers always know the live status.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>genie help uses your location for ride tracking, delivery progress, and nearby service discovery — even when the app is in the background.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>genie help uses Face ID to securely unlock your account and authorize transactions without passwords.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>genie help needs microphone access for voice messages in QualChat and voice commands to Genie AI.</string>
	<key>NSContactsUsageDescription</key>
	<string>genie help can read your contacts to help you find friends already on genie help and send them money or messages.</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>genie help uses this to deliver personalised recommendations and prevent fraud across the platform.</string>

	<!-- Deep Linking / Universal Links -->
	<key>FlutterDeepLinkingEnabled</key>
	<true/>

	<!-- Background Modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
		<string>location</string>
	</array>

	<!-- Status bar -->
	<key>UIStatusBarHidden</key>
	<false/>

	<!-- App Store category & export compliance -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.finance</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- URL scheme for Universal Links + custom geniehelp:// scheme -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>app.geniehelp</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>geniehelp</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
