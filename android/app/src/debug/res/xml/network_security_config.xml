<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- DEBUG ONLY: This file is used exclusively in debug builds. -->
    <!-- It allows cleartext traffic to localhost and the Android emulator host (10.0.2.2) only. -->
    <!-- NEVER include in release builds. -->
    <!-- Debug: Allow HTTPS by default, cleartext only for local dev -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Local development servers -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
